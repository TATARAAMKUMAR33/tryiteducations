  <title>TryIt Educations – Free Coaching SSC | Banking | Railways | TNPSC | UPSC</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Merriweather:wght@700;900&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --navy:#0d1f3c; --navy2:#162d50; --gold:#f5a623; --gold2:#ffcc60;
      --teal:#00b4a0; --red:#e53e3e; --green:#22c55e;
      --cream:#f7f3eb; --white:#ffffff; --text:#1a1a2e; --muted:#6b7280;
      --border:#dde3ef; --card:#ffffff; --shadow:0 4px 18px rgba(13,31,60,0.10);
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'Nunito',sans-serif;background:var(--cream);color:var(--text);line-height:1.65;font-size:15px;}
    a{text-decoration:none;color:inherit;}

    /* TICKER */
    .ticker-wrap{background:var(--gold);color:var(--navy);overflow:hidden;white-space:nowrap;padding:7px 0;font-weight:800;font-size:0.82rem;position:relative;z-index:200;}
    .ticker-label{display:inline-block;background:var(--navy);color:var(--gold);padding:2px 16px 2px 10px;margin-right:8px;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 50%,calc(100% - 10px) 100%,0 100%);font-size:0.76rem;letter-spacing:1px;}
    .ticker-track{display:inline-block;animation:ticker 40s linear infinite;}
    .ticker-track span{margin:0 2.5rem;}
    .ticker-track span::before{content:"🔔 ";}
    @keyframes ticker{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

    /* HEADER */
    header{background:var(--navy);position:sticky;top:0;z-index:150;box-shadow:0 2px 16px rgba(0,0,0,0.28);}
    .header-top{max-width:1200px;margin:auto;display:flex;align-items:center;justify-content:space-between;padding:0 1.2rem;height:62px;gap:1rem;}
    .logo{font-family:'Merriweather',serif;font-size:1.35rem;font-weight:900;color:#fff;white-space:nowrap;}
    .logo span{color:var(--gold);}
    .logo small{display:block;font-family:'Nunito',sans-serif;font-size:0.62rem;font-weight:600;color:rgba(255,255,255,0.5);letter-spacing:0.8px;margin-top:-3px;}
    .nav-links{display:flex;align-items:center;gap:0.2rem;flex-wrap:wrap;}
    .nav-links a{color:rgba(255,255,255,0.78);font-weight:700;font-size:0.82rem;padding:6px 11px;border-radius:6px;transition:background 0.18s,color 0.18s;}
    .nav-links a:hover{background:rgba(255,255,255,0.1);color:#fff;}
    .nav-links a.active{background:var(--gold);color:var(--navy);}
    .nav-cta{background:var(--teal)!important;color:#fff!important;border-radius:7px!important;font-weight:800!important;}
    .nav-cta:hover{background:#009e8c!important;}

    /* HERO */
    .hero{background:linear-gradient(135deg,var(--navy) 0%,var(--navy2) 55%,#1a4a7a 100%);color:#fff;padding:3.5rem 1.2rem 3rem;text-align:center;position:relative;overflow:hidden;}
    .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 75% 40%,rgba(245,166,35,0.13) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(0,180,160,0.10) 0%,transparent 55%);}
    .hero-inner{position:relative;max-width:800px;margin:auto;}
    .hero-eyebrow{display:inline-block;background:rgba(245,166,35,0.18);border:1px solid rgba(245,166,35,0.4);color:var(--gold2);padding:4px 14px;border-radius:999px;font-size:0.78rem;font-weight:800;letter-spacing:1px;text-transform:uppercase;margin-bottom:1rem;}
    .hero h1{font-family:'Merriweather',serif;font-size:clamp(1.7rem,4.5vw,2.9rem);font-weight:900;line-height:1.2;margin-bottom:0.9rem;}
    .hero h1 span{color:var(--gold);}
    .hero p{font-size:1rem;color:rgba(255,255,255,0.8);max-width:560px;margin:0 auto 1.8rem;}
    .hero-badges{display:flex;flex-wrap:wrap;justify-content:center;gap:0.5rem;margin-bottom:1.8rem;}
    .hero-badge{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);color:rgba(255,255,255,0.88);padding:5px 13px;border-radius:999px;font-size:0.78rem;font-weight:700;}
    .hero-btns{display:flex;flex-wrap:wrap;justify-content:center;gap:0.8rem;}
    .btn{display:inline-flex;align-items:center;gap:6px;padding:0.65rem 1.4rem;border-radius:9px;font-weight:800;font-size:0.9rem;cursor:pointer;transition:transform 0.15s,opacity 0.15s;border:none;}
    .btn:hover{transform:scale(1.04);}
    .btn-gold{background:var(--gold);color:var(--navy);}
    .btn-wa{background:#25d366;color:#fff;}
    .btn-tg{background:#0088cc;color:#fff;}
    .btn-outline{background:transparent;border:2px solid rgba(255,255,255,0.35);color:#fff;}

    /* SECTIONS */
    section{padding:0;}
    .section-inner{max-width:1200px;margin:auto;padding:2.5rem 1.2rem;}
    .sec-head{margin-bottom:1.6rem;}
    .sec-title{font-family:'Merriweather',serif;font-size:1.55rem;font-weight:900;color:var(--navy);margin-bottom:4px;}
    .sec-bar{width:44px;height:4px;background:var(--gold);border-radius:2px;margin:6px 0 8px;}
    .sec-sub{color:var(--muted);font-size:0.9rem;}

    /* EXAM CALENDAR */
    .exam-cal{background:#fff;border-bottom:3px solid var(--gold);}
    .cal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(265px,1fr));gap:1rem;}
    .cal-card{border:1.5px solid var(--border);border-radius:12px;padding:1.1rem 1.2rem;background:var(--cream);display:flex;gap:1rem;align-items:flex-start;transition:box-shadow 0.2s,transform 0.2s;}
    .cal-card:hover{box-shadow:var(--shadow);transform:translateY(-3px);}
    .cal-date-box{background:var(--navy);color:#fff;border-radius:9px;min-width:52px;text-align:center;padding:6px 4px;flex-shrink:0;}
    .cal-date-box .month{font-size:0.65rem;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--gold);}
    .cal-date-box .day{font-size:1.5rem;font-weight:900;line-height:1;}
    .cal-info h4{font-size:0.9rem;font-weight:800;color:var(--navy);line-height:1.3;margin-bottom:3px;}
    .cal-info p{font-size:0.78rem;color:var(--muted);}
    .cal-tag{display:inline-block;font-size:0.68rem;font-weight:800;padding:2px 7px;border-radius:4px;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.4px;}
    .tag-ssc{background:#dbeafe;color:#1d4ed8;}
    .tag-bank{background:#dcfce7;color:#15803d;}
    .tag-rail{background:#ffedd5;color:#c2410c;}
    .tag-upsc{background:#f3e8ff;color:#7e22ce;}
    .tag-tnpsc{background:#fef9c3;color:#854d0e;}
    .tag-result{background:#fee2e2;color:#b91c1c;}
    .notif-alert{margin-top:1.5rem;background:linear-gradient(90deg,var(--navy),var(--navy2));border-radius:12px;padding:1.1rem 1.4rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.8rem;color:#fff;}
    .notif-alert p{font-size:0.88rem;color:rgba(255,255,255,0.8);}
    .notif-alert strong{color:var(--gold);}

    /* CURRENT AFFAIRS */
    .ca-section{background:var(--cream);}
    .live-pill{display:inline-flex;align-items:center;gap:5px;background:#fee2e2;color:#b91c1c;padding:3px 10px;border-radius:999px;font-size:0.73rem;font-weight:800;}
    .live-dot{width:7px;height:7px;background:#ef4444;border-radius:50%;animation:pulse 1.3s infinite;}
    @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.25;}}
    .ca-tabs{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.4rem;}
    .ca-tab{padding:5px 14px;border-radius:7px;border:2px solid var(--border);font-weight:700;font-size:0.82rem;cursor:pointer;background:#fff;color:var(--navy);transition:all 0.18s;}
    .ca-tab.active,.ca-tab:hover{background:var(--navy);color:#fff;border-color:var(--navy);}
    .ca-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:1rem;}
    .ca-card{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:1.15rem;transition:box-shadow 0.2s,transform 0.2s;}
    .ca-card:hover{box-shadow:var(--shadow);transform:translateY(-3px);}
    .ca-tag2{display:inline-block;font-size:0.68rem;font-weight:800;padding:2px 8px;border-radius:4px;margin-bottom:7px;text-transform:uppercase;letter-spacing:0.5px;}
    .tag-nat{background:#dbeafe;color:#1d4ed8;}
    .tag-eco{background:#dcfce7;color:#15803d;}
    .tag-sci{background:#f3e8ff;color:#7e22ce;}
    .tag-spo{background:#ffedd5;color:#c2410c;}
    .tag-int{background:#e0f2fe;color:#0369a1;}
    .tag-awd{background:#fef9c3;color:#854d0e;}
    .ca-card h4{font-size:0.92rem;font-weight:800;line-height:1.4;margin-bottom:5px;color:var(--navy);}
    .ca-card p{font-size:0.82rem;color:var(--muted);line-height:1.5;}
    .ca-date{font-size:0.73rem;color:#9ca3af;margin-top:8px;}
    .ca-quiz-cta{margin-top:1.6rem;background:linear-gradient(135deg,var(--navy),#1a4a7a);border-radius:14px;padding:1.5rem 1.6rem;color:#fff;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
    .ca-quiz-cta h3{font-family:'Merriweather',serif;font-size:1.1rem;margin-bottom:3px;}
    .ca-quiz-cta p{font-size:0.85rem;color:rgba(255,255,255,0.72);}

    /* EDITORIAL */
    .editorial{background:#fff;border-top:3px solid var(--teal);}
    .ed-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.1rem;}
    .ed-card{border:1.5px solid var(--border);border-radius:12px;overflow:hidden;background:var(--cream);transition:box-shadow 0.2s,transform 0.2s;}
    .ed-card:hover{box-shadow:var(--shadow);transform:translateY(-3px);}
    .ed-header{background:var(--navy);padding:0.85rem 1.1rem;display:flex;align-items:center;gap:0.6rem;}
    .ed-icon{font-size:1.3rem;}
    .ed-header h4{color:#fff;font-size:0.92rem;font-weight:800;}
    .ed-header span{margin-left:auto;font-size:0.68rem;font-weight:800;background:var(--gold);color:var(--navy);padding:2px 8px;border-radius:4px;}
    .ed-body{padding:1rem 1.1rem;}
    .ed-body p{font-size:0.83rem;color:var(--muted);margin-bottom:0.8rem;}
    .ed-links a{display:flex;align-items:center;gap:6px;font-size:0.82rem;font-weight:700;color:var(--navy);padding:5px 0;border-bottom:1px dashed var(--border);transition:color 0.15s;}
    .ed-links a:last-child{border-bottom:none;}
    .ed-links a:hover{color:var(--teal);}
    .tg-banner{margin-top:1.6rem;background:linear-gradient(135deg,#0088cc,#006fa3);border-radius:14px;padding:1.4rem 1.6rem;color:#fff;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
    .tg-banner h3{font-size:1.05rem;font-weight:800;margin-bottom:3px;}
    .tg-banner p{font-size:0.83rem;color:rgba(255,255,255,0.78);}

    /* COURSES */
    .courses{background:var(--cream);}
    .courses-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:1.1rem;}
    .course-card{background:var(--card);border:1.5px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:var(--shadow);transition:transform 0.2s;}
    .course-card:hover{transform:translateY(-5px);}
    .course-top{background:linear-gradient(135deg,var(--navy),#1a4a7a);padding:1.2rem;color:#fff;position:relative;}
    .course-top .badge-free{position:absolute;top:10px;right:10px;background:var(--green);color:#fff;font-size:0.68rem;font-weight:800;padding:2px 8px;border-radius:4px;}
    .course-top h3{font-family:'Merriweather',serif;font-size:1rem;margin-bottom:3px;}
    .course-top p{font-size:0.78rem;color:rgba(255,255,255,0.72);}
    .course-body{padding:1rem 1.1rem;}
    .course-features{list-style:none;margin-bottom:1rem;}
    .course-features li{font-size:0.83rem;color:var(--muted);padding:3px 0;}
    .course-features li::before{content:"✅ ";font-size:0.8rem;}
    .course-price{display:flex;align-items:center;gap:0.6rem;margin-bottom:0.9rem;}
    .price-free{font-size:1.2rem;font-weight:900;color:var(--green);}
    .price-old{font-size:0.85rem;color:var(--muted);text-decoration:line-through;}
    .btn-buy{display:flex;align-items:center;justify-content:center;gap:6px;width:100%;padding:0.65rem;background:#25d366;color:#fff;border:none;border-radius:9px;font-weight:800;font-size:0.88rem;cursor:pointer;transition:background 0.18s,transform 0.15s;text-decoration:none;}
    .btn-buy:hover{background:#1ebe5d;transform:scale(1.02);}

    /* SUBJECTS */
    .subjects{background:#fff;}
    .subj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:0.9rem;}
    .subj-card{background:var(--cream);border:1.5px solid var(--border);border-radius:12px;padding:1.1rem 0.9rem;text-align:center;cursor:pointer;transition:transform 0.18s,box-shadow 0.18s,background 0.18s,color 0.18s;}
    .subj-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);background:var(--navy);color:#fff;border-color:var(--navy);}
    .subj-card:hover p{color:rgba(255,255,255,0.6);}
    .subj-card .icon{font-size:2rem;margin-bottom:5px;}
    .subj-card h3{font-size:0.88rem;font-weight:800;}
    .subj-card p{font-size:0.73rem;color:var(--muted);margin-top:3px;}

    /* EXAMS */
    .exams{background:var(--cream);}
    .exam-chips{display:flex;flex-wrap:wrap;gap:0.7rem;}
    .exam-chip{border:2px solid var(--navy);color:var(--navy);border-radius:8px;padding:6px 14px;font-size:0.85rem;font-weight:800;cursor:pointer;transition:background 0.18s,color 0.18s;}
    .exam-chip.active,.exam-chip:hover{background:var(--navy);color:#fff;}

    /* CONTACT */
    .contact{background:#fff;border-top:3px solid var(--gold);}
    .contact-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.1rem;}
    .contact-card{border:1.5px solid var(--border);border-radius:12px;padding:1.3rem;text-align:center;background:var(--cream);transition:box-shadow 0.2s,transform 0.2s;}
    .contact-card:hover{box-shadow:var(--shadow);transform:translateY(-3px);}
    .contact-card .c-icon{font-size:2.2rem;margin-bottom:0.5rem;}
    .contact-card h4{font-size:1rem;font-weight:800;margin-bottom:4px;color:var(--navy);}
    .contact-card p{font-size:0.83rem;color:var(--muted);margin-bottom:0.8rem;}
    .clink{display:inline-flex;align-items:center;gap:5px;padding:7px 16px;border-radius:8px;font-weight:800;font-size:0.85rem;transition:transform 0.15s;}
    .clink:hover{transform:scale(1.04);}
    .clink-wa{background:#25d366;color:#fff;}
    .clink-tg{background:#0088cc;color:#fff;}
    .clink-mail{background:var(--navy);color:#fff;}
    .clink-call{background:var(--gold);color:var(--navy);}

    /* FOOTER */
    footer{background:var(--navy);color:rgba(255,255,255,0.65);padding:2.2rem 1.2rem 1.4rem;}
    .footer-inner{max-width:1200px;margin:auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.5rem;margin-bottom:1.5rem;}
    .footer-col h5{color:var(--gold);font-size:0.82rem;font-weight:800;letter-spacing:0.8px;text-transform:uppercase;margin-bottom:0.7rem;}
    .footer-col a{display:block;color:rgba(255,255,255,0.6);font-size:0.83rem;margin-bottom:5px;transition:color 0.15s;}
    .footer-col a:hover{color:var(--gold);}
    .footer-col p{font-size:0.82rem;line-height:1.6;}
    .footer-bottom{max-width:1200px;margin:auto;border-top:1px solid rgba(255,255,255,0.08);padding-top:1rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;font-size:0.78rem;}

    /* FLOATING BUTTONS */
    .fab-group{position:fixed;bottom:1.4rem;right:1.2rem;display:flex;flex-direction:column;gap:0.6rem;z-index:999;}
    .fab{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;box-shadow:0 4px 16px rgba(0,0,0,0.25);cursor:pointer;transition:transform 0.18s;text-decoration:none;}
    .fab:hover{transform:scale(1.12);}
    .fab-wa{background:#25d366;}
    .fab-tg{background:#0088cc;}

    @media(max-width:640px){
      .nav-links{display:none;}
      .hero h1{font-size:1.6rem;}
      .logo{font-size:1.1rem;}
    }
  </style>
</head> 
